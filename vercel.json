{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": ["syd1"],
  "buildCommand": "npx prisma generate && npx prisma db push --accept-data-loss && next build",
  "crons": [
    {
      "path": "/api/cron/inspection-reminders",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/overdue-reminders",
      "schedule": "0 9 * * 1-5"
    },
    {
      "path": "/api/cron/audit-cleanup",
      "schedule": "0 3 1 * *"
    },
    {
      "path": "/api/cron/predictions",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/run-workflows",
      "schedule": "0 */6 * * *"
    }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/manifest.webmanifest",
      "headers": [
        { "key": "Content-Type", "value": "application/manifest+json" }
      ]
    }
  ]
}
